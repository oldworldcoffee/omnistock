{
  "name": "StorageArea",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Company ID this storage area belongs to"
    },
    "name": {
      "type": "string",
      "description": "e.g. Front Counter, Back Counter, Walk-in Cooler"
    },
    "location_id": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "location_id",
    "company_id"
  ]
}